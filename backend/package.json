{
  "name": "tcg-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Pokemon TCG Gacha — read-replica API + Sepolia event indexer",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:indexer": "tsx watch src/indexer.ts",
    "start": "node --experimental-specifier-resolution=node --loader tsx src/index.ts",
    "start:indexer": "tsx src/indexer.ts",
    "build": "tsc",
    "seed": "tsx src/lib/seed.ts",
    "copy-abi": "tsx src/lib/copy-abi.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "setup": "npm run copy-abi && npm run prisma:generate && npm run prisma:migrate && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
