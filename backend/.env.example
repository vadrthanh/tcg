# SQLite database file path (relative to /backend)
DATABASE_URL="file:./dev.db"

# Sepolia RPC — HTTPS works for catch-up; WSS needed for live subscriptions.
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"
SEPOLIA_RPC_WSS=""

# Indexer behaviour
INDEXER_START_BLOCK=0        # 0 = use deploy block from addresses.json, or set explicit block
INDEXER_POLL_INTERVAL_MS=15000  # poll fallback when WSS not configured
INDEXER_BATCH_BLOCKS=2000      # blocks per getLogs batch during catch-up

# API
PORT=4000
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100

# Contract addresses.
# Preferred: run contracts/scripts/deploy.ts so contracts/deploy/addresses.json exists locally.
# Alternative: set these values directly; VITE_* equivalents are also accepted.
CHAIN_ID=11155111
CONTRACT_NETWORK=sepolia
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
POKEMON_CARD_NFT_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_SPLITTER_ADDRESS=0x0000000000000000000000000000000000000000
GACHA_PACK_ADDRESS=0x0000000000000000000000000000000000000000
MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOY_BLOCK=0
